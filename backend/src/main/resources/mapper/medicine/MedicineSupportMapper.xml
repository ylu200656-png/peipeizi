<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
    PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yaojie.modules.medicine.mapper.MedicineSupportMapper">

    <select id="selectCategoryList" resultType="com.yaojie.modules.medicine.vo.MedicineCategoryVO">
        SELECT id, category_name, category_code, remark
        FROM medicine_category
        ORDER BY id ASC
    </select>

    <select id="selectSupplierList" resultType="com.yaojie.modules.medicine.vo.SupplierVO">
        SELECT id, supplier_name, contact_person, phone, address, status
        FROM supplier
        WHERE status = 1
        ORDER BY id ASC
    </select>
</mapper>
