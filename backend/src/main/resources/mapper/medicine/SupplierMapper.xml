<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
    PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yaojie.modules.medicine.mapper.SupplierMapper">

    <resultMap id="SupplierMap" type="com.yaojie.modules.medicine.entity.Supplier">
        <id property="id" column="id"/>
        <result property="supplierName" column="supplier_name"/>
        <result property="status" column="status"/>
    </resultMap>

    <select id="selectById" resultMap="SupplierMap">
        SELECT id, supplier_name, status
        FROM supplier
        WHERE id = #{id}
        LIMIT 1
    </select>
</mapper>
