<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
    PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yaojie.modules.system.mapper.SysRoleMapper">

    <select id="selectList" resultType="com.yaojie.modules.system.vo.SysRoleVO">
        SELECT
            id,
            role_code,
            role_name
        FROM sys_role
        ORDER BY id ASC
    </select>

    <select id="selectByIds" resultType="com.yaojie.modules.system.vo.SysRoleVO">
        SELECT
            id,
            role_code,
            role_name
        FROM sys_role
        WHERE id IN
        <foreach collection="roleIds" item="roleId" open="(" separator="," close=")">
            #{roleId}
        </foreach>
        ORDER BY id ASC
    </select>
</mapper>
